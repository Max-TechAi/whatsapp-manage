{
  "name": "whatsapp-business-api",
  "version": "1.0.0",
  "description": "Self-hosted WhatsApp Business API platform with multi-tenant support",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file=.env watch src/index.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "session-runner:dev": "tsx --env-file=.env watch src/session-runner.ts",
    "session-runner:start": "node --env-file=.env dist/session-runner.js",
    "worker": "tsx --env-file=.env src/events/worker-entry.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=.env src/db/migrate.ts",
    "db:migrate:prod": "node dist/db/migrate.js",
    "db:cleanup-lid": "tsx --env-file=.env src/scripts/cleanup-lid-duplicates.ts",
    "db:cleanup-lid:prod": "node dist/scripts/cleanup-lid-duplicates.js",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest"
  },
  "dependencies": {
    "@bull-board/api": "^6.5.0",
    "@bull-board/express": "^6.5.0",
    "@types/nodemailer": "^8.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.13",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.30.0",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.39.0",
    "express": "^4.21.0",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "minio": "^8.0.2",
    "nodemailer": "^9.0.1",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.5",
    "uuid": "^10.0.0",
    "winston": "^3.15.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
