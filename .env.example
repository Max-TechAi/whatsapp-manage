# PostgreSQL
DATABASE_URL=postgresql://whatsapp:secret_password@localhost:5432/whatsapp_db
DB_PASSWORD=secret_password
DB_POOL_MAX=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_password

# MinIO (S3-compatible)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minio_secret_password
MINIO_BUCKET=whatsapp-media
MINIO_USE_SSL=false

# JWT Authentication
JWT_SECRET=change-me-to-a-256-bit-secret-key-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# AES-256 Encryption (32 bytes hex = 64 hex chars)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Server
PORT=3000
WS_PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Grafana
GRAFANA_PASSWORD=admin

# Rate Limiting
RATE_LIMIT_AUTH=5
RATE_LIMIT_API=100
RATE_LIMIT_WA_MESSAGES=20
